            "description": "Lists flows visible to the authenticated user. Optional query params: search, status.",
            "url": {
              "raw": "{{baseUrl}}/v1/flows",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "v1",
                "flows"
              ],
