        {
          "name": "Update Variable",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "description": "Partially updates a variable. Body is variableSchema.partial(), so every field is optional.",
