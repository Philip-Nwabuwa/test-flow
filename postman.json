        {
          "name": "Create Schedule",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "description": "Creates a schedule for a flow. Body matches scheduleSchema. frequency must be hourly or daily. For daily schedules include hour. For hourly schedules include everyHours. retryPolicy is required.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"frequency\": \"daily\",\n  \"timezone\": \"{{timezone}}\",\n  \"minute\": 0,\n  \"hour\": 9,\n  \"everyHours\": null,\n  \"environment\": \"production\",\n  \"enabled\": true,\n  \"retryPolicy\": {\n    \"attempts\": 3,\n    \"backoffType\": \"exponential\",\n    \"backoffMs\": 60000\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/flows/{{flowId}}/schedules",
              "host": [
                "{{baseUrl}}"
              ],
