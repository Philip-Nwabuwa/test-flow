        {
          "name": "Save Draft",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "description": "Replaces the draft payload for a flow. The body matches flowDraftPayloadSchema and must contain at least one step.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"intent\": \"Validate checkout can complete successfully.\",\n  \"targetUrl\": \"https://example.com/checkout\",\n  \"executionMode\": \"headed\",\n  \"healthStatus\": \"untested\",\n  \"steps\": [\n    {\n      \"sortOrder\": 0,\n      \"actionType\": \"navigate\",\n      \"semanticLabel\": \"Open checkout page\",\n      \"selector\": null,\n      \"value\": \"https://example.com/checkout\",\n      \"expectedOutcome\": \"Checkout page loads\",\n      \"timeoutMs\": 30000\n    },\n    {\n      \"sortOrder\": 1,\n      \"actionType\": \"input\",\n      \"semanticLabel\": \"Enter email\",\n      \"selector\": \"input[name='email']\",\n      \"value\": \"user@example.com\",\n      \"expectedOutcome\": \"Email field is populated\",\n      \"timeoutMs\": 10000\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/flows/{{flowId}}/draft",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "v1",
                "flows",
                "{{flowId}}",
                "draft"
              ],
              "variable": [
                {
                  "key": "flowId",
                  "value": "{{flowId}}"
                }
              ]
            }
          }
        },
