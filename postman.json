                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "description": "Updates a flow. All fields are optional. Allowed status values: draft, active, paused, passed, failed. Allowed healthStatus values: healthy, failing, untested.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Checkout flow v2\",\n  \"status\": \"active\",\n  \"targetUrl\": \"https://example.com/checkout\",\n  \"flowType\": \"ui\",\n  \"intent\": \"Validate checkout and payment success.\",\n  \"healthStatus\": \"healthy\"\n}"
            },
