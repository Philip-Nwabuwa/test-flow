        {
          "name": "Create Flow",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "description": "Creates a flow. The body matches flowCreateSchema. draft.steps requires at least one step. Allowed actionType values: click, input, select, navigate, wait, scroll, KeyPress, assert. Allowed healthStatus values: healthy, failing, untested.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"projectId\": \"{{projectId}}\",\n  \"name\": \"Checkout flow\",\n  \"targetUrl\": \"https://example.com/checkout\",\n  \"flowType\": \"ui\",\n  \"draft\": {\n    \"intent\": \"Validate checkout can complete successfully.\",\n    \"targetUrl\": \"https://example.com/checkout\",\n    \"executionMode\": \"headed\",\n    \"healthStatus\": \"untested\",\n    \"steps\": [\n      {\n        \"sortOrder\": 0,\n        \"actionType\": \"navigate\",\n        \"semanticLabel\": \"Open checkout page\",\n        \"selector\": null,\n        \"value\": \"https://example.com/checkout\",\n        \"expectedOutcome\": \"Checkout page loads\",\n        \"timeoutMs\": 30000\n      },\n      {\n        \"sortOrder\": 1,\n        \"actionType\": \"click\",\n        \"semanticLabel\": \"Click checkout button\",\n        \"selector\": \"button[data-testid='checkout']\",\n        \"value\": null,\n        \"expectedOutcome\": \"Payment form is visible\",\n        \"timeoutMs\": 10000\n      }\n    ]\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/flows",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "v1",
                "flows"
              ]
            }
          }
        },
        {
          "name": "Get Flow",
          "request": {
            "method": "GET",
            "description": "Fetches a single flow by UUID.",
            "url": {
              "raw": "{{baseUrl}}/v1/flows/{{flowId}}",
