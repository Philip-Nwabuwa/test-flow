              }
            ],
            "description": "Creates a variable. name must be upper snake case and value must be 1 to 4000 chars.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"projectId\": \"{{projectId}}\",\n  \"flowId\": \"{{flowId}}\",\n  \"name\": \"LOGIN_EMAIL\",\n  \"value\": \"user@example.com\",\n  \"description\": \"Credential used for login automation\"\n}"
            },
